{
  "name": "pug-tail",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pug-tail": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "npm run test:dev",
    "build": "tsc && tsc-alias",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:dev": "vitest --ui",
    "check": "npm run check:format && npm run check:lint && npm run check:types",
    "check:format": "biome format .",
    "check:lint": "biome lint .",
    "check:types": "tsc --noEmit",
    "fix": "biome check --write ."
  },
  "keywords": [
    "pug",
    "template",
    "component",
    "slot",
    "transpiler",
    "ast",
    "build-tool",
    "static-expansion",
    "zero-runtime"
  ],
  "author": "megurock",
  "license": "MIT",
  "description": "A transpiler that statically expands component DSL with slot syntax on Pug AST",
  "repository": {
    "type": "git",
    "url": "https://github.com/megurock/pug-tail.git"
  },
  "dependencies": {
    "pug-code-gen": "^3.0.3",
    "pug-lexer": "^5.0.1",
    "pug-parser": "^6.0.0",
    "pug-walk": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "commitlint": "^20.2.0",
    "lefthook": "^2.0.13",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
